  "inbounds": [
    //仅支持Linux和macOS
    //端口建议：Ports with numbers 0–1023 are called system or well-known ports; ports with numbers 1024-49151 are called user or registered ports, and ports with numbers 49152-65535 are called dynamic, private or ephemeral ports.
    //即：0到1023的端口号被称为众所周知端口（Well-known Ports），用于一些特定的服务或应用程序。1024到49151的端口号被称为注册端口（Registered Ports），用于一些注册的应用程序或服务。49152到65535的端口号被称为动态和/或私有端口（Dynamic and/or Private Ports），用于临时分配或私有网络使用。
    /*{
      "type": "direct",
      "tag": "dns-in",
      "listen": "::",
      //"listen_port": 1023,
      "listen_port": 1024,
      "network": "udp",
      "override_address": "8.8.8.8",
      "override_port": 53,
      //"users": [{}]
    },
    {
      "type": "redirect",
      "tag": "redirect-in",
      "listen": "::",
      "listen_port": 49151,
      //"listen_port": 49152,
      //"users": [{}]
